@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="hero-section">

    <div class="container text-center py-4">

        <h1 class="display-5 fw-bold">
            Supermarket Management System
        </h1>

        <p class="lead mt-2">
            Manage products, inventory, stock and daily sales for your supermarket.
        </p>

        <div class="mt-3">

            <a href="/Accounts/Register" class="btn btn-success m-2">
                Register
            </a>

            <a href="/Accounts/Login" class="btn btn-light m-2">
                Login
            </a>

            <a href="/Dashboard" class="btn btn-dark m-2">
                Dashboard
            </a>

        </div>

    </div>

</div>


<div class="container mt-4">

    <h2 class="text-center mb-4">
        System Features
    </h2>

    <div class="row">

        <div class="col-md-4">

            <div class="feature-box">

                <h4>Product Management</h4>

                <p>
                    Add supermarket products with image, price,
                    manufacturing date and expiry date.
                </p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="feature-box">

                <h4>Inventory Control</h4>

                <p>
                    Manage stock quantity and monitor available
                    supermarket inventory easily.
                </p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="feature-box">

                <h4>Sales Tracking</h4>

                <p>
                    Record product sales and automatically update stock
                    after each sale.
                </p>

            </div>

        </div>

    </div>

</div>