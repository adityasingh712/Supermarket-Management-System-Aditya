@page
@model SupermarketManagementAditya.Pages.Products.EditProductModel
@{
    ViewData["Title"] = "Edit Product";
}

<div class="container mt-5">

    <div class="card shadow p-4">

        <h2>Edit Product</h2>
        <p class="text-muted">Update supermarket product details</p>

        <form method="post" enctype="multipart/form-data">

            <input type="hidden" asp-for="Product.Id" />
            <input type="hidden" asp-for="Product.ImagePath" />

            @if (!string.IsNullOrEmpty(Model.Product.ImagePath))
            {
                <div class="mb-3">
                    <label>Current Product Image</label><br />
                    <img src="@Model.Product.ImagePath" width="120" height="120" style="object-fit:cover;" />
                </div>
            }

            <div class="mb-3">
                <label>Change Product Image</label>
                <input asp-for="ImageFile" type="file" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Product Name</label>
                <input asp-for="Product.ProductName" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Category</label>
                <input asp-for="Product.Category" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Supplier</label>
                <input asp-for="Product.Supplier" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Barcode</label>
                <input asp-for="Product.Barcode" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Price</label>
                <input asp-for="Product.Price" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Quantity</label>
                <input asp-for="Product.Quantity" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Manufacturing Date</label>
                <input asp-for="Product.ManufacturingDate" type="date" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Expiry Date</label>
                <input asp-for="Product.ExpiryDate" type="date" class="form-control" />
            </div>

            <button type="submit" class="btn btn-success">
                Update Product
            </button>

            <a href="/Products/ProductList" class="btn btn-secondary">
                Back
            </a>

        </form>

    </div>

</div>