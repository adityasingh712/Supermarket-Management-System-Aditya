@page
@model SupermarketManagementAditya.Pages.Products.ExpiredProductsModel
@{
    ViewData["Title"] = "Expired Products";
}

<div class="container mt-5">

    <h2>Expired Products</h2>
    <p class="text-muted">Products that are already expired</p>

    <div class="card shadow p-3">

        <table class="table table-bordered table-hover">

            <thead class="table-danger">
                <tr>
                    <th>Image</th>
                    <th>Product Name</th>
                    <th>Supplier</th>
                    <th>Quantity</th>
                    <th>Expiry Date</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Products)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImagePath))
                            {
                                <img src="@item.ImagePath" width="60" height="60" style="object-fit:cover;" />
                            }
                            else
                            {
                                <span>No Image</span>
                            }
                        </td>

                        <td>@item.ProductName</td>
                        <td>@item.Supplier</td>
                        <td>@item.Quantity</td>
                        <td>@item.ExpiryDate.ToShortDateString()</td>

                        <td>
                            <span class="badge bg-danger">Expired</span>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>

</div>