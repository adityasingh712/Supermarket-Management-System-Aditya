@page
@model SupermarketManagementAditya.Pages.Products.ExpiringSoonModel
@{
    ViewData["Title"] = "Expiring Soon";
}

<div class="container mt-5">

    <h2>Expiring Soon Products</h2>
    <p class="text-muted">Products that are expired or expiring within 30 days</p>

    <div class="card shadow p-3">

        <table class="table table-bordered">

            <thead class="table-warning">
                <tr>
                    <th>Image</th>
                    <th>Product Name</th>
                    <th>Supplier</th>
                    <th>Quantity</th>
                    <th>Expiry Date</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Products)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImagePath))
                            {
                                <img src="@item.ImagePath" width="60" height="60" />
                            }
                            else
                            {
                                <span>No Image</span>
                            }
                        </td>

                        <td>@item.ProductName</td>
                        <td>@item.Supplier</td>
                        <td>@item.Quantity</td>
                        <td>@item.ExpiryDate.ToShortDateString()</td>

                        <td>
                            @if (item.ExpiryDate < DateTime.Today)
                            {
                                <span class="badge bg-danger">Expired</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Expiring Soon</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>

    <a href="/Dashboard" class="btn btn-secondary mt-3">
        Back to Dashboard
    </a>

</div>