@page
@model SupermarketManagementAditya.Pages.Reports.ReportsIndexModel
@{
    ViewData["Title"] = "Reports";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Reports Dashboard</h2>
            <p class="text-muted">Simple reports for supermarket management</p>
        </div>

        <a class="btn btn-danger" href="/Reports/ReportsIndex?handler=DownloadPdf">
            Download PDF Report
        </a>
    </div>

    <div class="card shadow p-3 mb-4">
        <h4>Low Stock Items</h4>

        <table class="table table-bordered">
            <thead class="table-danger">
                <tr>
                    <th>Product</th>
                    <th>Supplier</th>
                    <th>Quantity</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.LowStockItems)
                {
                    <tr>
                        <td>@item.ProductName</td>
                        <td>@item.Supplier</td>
                        <td>@item.Quantity</td>
                        <td>@item.StockStatus</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card shadow p-3 mb-4">
        <h4>Sales By Product</h4>

        <table class="table table-bordered">
            <thead class="table-success">
                <tr>
                    <th>Product</th>
                    <th>Quantity Sold</th>
                    <th>Total Revenue</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var sale in Model.SalesByProduct)
                {
                    <tr>
                        <td>@sale.ProductName</td>
                        <td>@sale.TotalQuantitySold</td>
                        <td>£@sale.TotalRevenue</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card shadow p-3 mb-4">
        <h4>Products By Category</h4>

        <table class="table table-bordered">
            <thead class="table-primary">
                <tr>
                    <th>Category</th>
                    <th>Total Products</th>
                    <th>Total Stock</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.ProductsByCategory)
                {
                    <tr>
                        <td>@item.Category</td>
                        <td>@item.TotalProducts</td>
                        <td>@item.TotalStock</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card shadow p-3 mb-4">
        <h4>Supplier Stock List</h4>

        <table class="table table-bordered">
            <thead class="table-warning">
                <tr>
                    <th>Supplier</th>
                    <th>Total Products</th>
                    <th>Total Stock</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.SupplierStockLists)
                {
                    <tr>
                        <td>@item.Supplier</td>
                        <td>@item.TotalProducts</td>
                        <td>@item.TotalStock</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>