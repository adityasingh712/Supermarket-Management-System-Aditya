@page "/Sales"
@model SupermarketManagementAditya.Pages.Sales.SalesIndexModel
@{
    ViewData["Title"] = "Sales";
}

<div class="container mt-5">

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card shadow p-4 text-center">
                <h4>Total Revenue</h4>
                <h2>£@Model.TotalRevenue</h2>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow p-4 text-center">
                <h4>Total Items Sold</h4>
                <h2>@Model.TotalItemsSold</h2>
            </div>
        </div>
    </div>

    <div class="card p-4 shadow mb-4">

        <h2>Sales Management</h2>
        <p class="text-muted">Record product sales and update stock automatically</p>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert alert-info">
                @Model.Message
            </div>
        }

        <form method="post">

            <div class="mb-3">
                <label>Select Product</label>

                <select asp-for="SelectedProductId" class="form-control">
                    @foreach (var item in Model.Products)
                    {
                        <option value="@item.Id">
                            @item.ProductName - Stock: @item.Quantity - £@item.Price
                        </option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label>Quantity Sold</label>
                <input asp-for="QuantitySold"
                       class="form-control"
                       type="number"
                       min="1" />
            </div>

            <button class="btn btn-success" type="submit">
                Save Sale
            </button>

        </form>

    </div>

    <div class="card shadow p-3">

        <h4>Sales History</h4>

        <table class="table table-bordered">

            <thead class="table-dark">
                <tr>
                    <th>Product</th>
                    <th>Quantity Sold</th>
                    <th>Total Amount</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var sale in Model.SalesHistory)
                {
                    <tr>
                        <td>@sale.ProductName</td>
                        <td>@sale.QuantitySold</td>
                        <td>£@sale.TotalAmount</td>
                    </tr>
                }
            </tbody>

        </table>

    </div>

</div>