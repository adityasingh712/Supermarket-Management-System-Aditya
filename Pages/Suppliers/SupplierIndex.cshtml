@page
@model SupermarketManagementAditya.Pages.Suppliers.SupplierIndexModel
@{
    ViewData["Title"] = "Suppliers";
}

<div class="container mt-5">

    <h2>Supplier Dashboard</h2>
    <p class="text-muted">View suppliers and the products they provide</p>

    @foreach (var supplier in Model.SupplierGroups)
    {
        <div class="card shadow p-4 mb-4">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h4>@supplier.SupplierName</h4>
                    <p class="text-muted">Products supplied by this supplier</p>
                </div>

                <div>
                    <span class="badge bg-success fs-6">
                        Total Products: @supplier.Products.Count
                    </span>

                    <a href="/Suppliers/EditSupplier?name=@supplier.SupplierName"
                       class="btn btn-warning ms-2">
                        Edit Supplier
                    </a>
                </div>
            </div>

            <div class="row">

                @foreach (var product in supplier.Products)
                {
                    <div class="col-md-3 mb-3">

                        <div class="card h-100">

                            @if (!string.IsNullOrEmpty(product.ImagePath))
                            {
                                <img src="@product.ImagePath"
                                     class="card-img-top"
                                     style="height:150px; object-fit:cover;" />
                            }
                            else
                            {
                                <div class="text-center p-5 bg-light">
                                    No Image
                                </div>
                            }

                            <div class="card-body">
                                <h5 class="card-title">@product.ProductName</h5>
                                <p class="card-text">
                                    Category: @product.Category <br />
                                    Quantity: @product.Quantity <br />
                                    Price: £@product.Price
                                </p>
                            </div>

                        </div>

                    </div>
                }

            </div>

        </div>
    }

</div>